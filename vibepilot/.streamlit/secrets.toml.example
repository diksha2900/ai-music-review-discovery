# Copy to .streamlit/secrets.toml and fill in. NEVER commit the real secrets.toml.

# Spotify Developer app (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID = "your_client_id_here"
SPOTIFY_CLIENT_SECRET = "your_client_secret_here"
# Must EXACTLY match a Redirect URI registered in your Spotify app settings.
# Local dev:  http://127.0.0.1:8502
# Production: https://<your-app>.streamlit.app
SPOTIFY_REDIRECT_URI = "http://127.0.0.1:8502"

# Groq (https://console.groq.com)
GROQ_API_KEY = "your_groq_key_here"

# Last.fm (https://www.last.fm/api/account/create) — real song-similarity engine
LASTFM_API_KEY = "your_lastfm_api_key_here"
